{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3ToSend",
      "Effect": "Allow",
      "Principal": {
        "Service": "s3.amazonaws.com"
      },
      "Action": "sqs:SendMessage",
      "Resource": "arn:aws:sqs:us-east-1:000000000000:floci-sqs",
      "Condition": {
        "ArnEquals": {
          "aws:SourceArn": "arn:aws:s3:::file-upload"
        }
      }
    }
  ]
}